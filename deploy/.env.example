# =============================================================================
# Chegou — produção (single-server). Copie para deploy/.env e preencha.
#   cp .env.example .env && nano .env
# NUNCA commite o .env (já está no .gitignore).
# =============================================================================

# ---- Domínio / TLS -----------------------------------------------------------
DOMAIN=chegou.bellory.com.br
LETSENCRYPT_EMAIL=voce@bellory.com.br
# 1 = usa o ambiente de teste do Let's Encrypt (cert não confiável, sem limite de tentativas).
# Deixe 0 para o certificado real. Use 1 só se estiver depurando emissão.
CERTBOT_STAGING=0

# (As imagens api/web são buildadas no próprio servidor — não há registry a configurar.)

# ---- Banco de dados ----------------------------------------------------------
# Gere uma senha forte: openssl rand -hex 24
POSTGRES_PASSWORD=troque-esta-senha-do-postgres

# ---- Auth --------------------------------------------------------------------
# Gere: openssl rand -hex 32   (mínimo 16 chars)
JWT_SECRET=troque-por-um-segredo-aleatorio-de-32-chars
JWT_EXPIRES_IN=12h
BCRYPT_ROUNDS=12

# ---- Superadmin inicial (criado por: docker compose exec api node scripts/seed-prod.js)
SUPERADMIN_EMAIL=admin@bellory.com.br
SUPERADMIN_PASSWORD=troque-esta-senha-do-superadmin
SUPERADMIN_NOME=Super Admin

# ---- WhatsApp ----------------------------------------------------------------
WHATSAPP_PROVIDER=twilio
# Número remetente E.164 (obrigatório p/ subir). Ex.: sandbox Twilio = +14155238886
WHATSAPP_FROM_NUMBER=+14155238886
WHATSAPP_SANDBOX_MODE=false
WHATSAPP_WEBHOOK_VERIFY=true

# Twilio (deixe em branco se ainda não usa)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=
TWILIO_TEMPLATE_ENCOMENDA_CHEGOU=
TWILIO_TEMPLATE_RETIRADA_CONFIRMADA=

# Z-API (alternativa ao Twilio)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=

# ---- Storage de fotos (MinIO no Docker) --------------------------------------
MINIO_ROOT_USER=chegou
# Gere: openssl rand -hex 20
MINIO_ROOT_PASSWORD=troque-esta-senha-do-minio
STORAGE_BUCKET=portaria-fotos
