NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ---- Database ----
DATABASE_URL=postgresql://portaria:portaria@localhost:5433/portaria_dev
DATABASE_POOL_SIZE=10

# ---- Redis (BullMQ) ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
JWT_SECRET=change-me-in-prod-please
JWT_EXPIRES_IN=12h
BCRYPT_ROUNDS=12

# ---- WhatsApp (BSP) ----
# Provider em uso: twilio | zapi | gupshup
WHATSAPP_PROVIDER=twilio
WHATSAPP_FROM_NUMBER=+5511999999999
# Em dev/sandbox, envia free-form text em vez de template (Twilio Sandbox aceita)
WHATSAPP_SANDBOX_MODE=true
# Em prod, mantenha true. Em dev pode desligar (false) pra testar webhook sem assinatura.
WHATSAPP_WEBHOOK_VERIFY=false
# Necessário em prod atrás de proxy/load-balancer pra validar assinatura corretamente.
# Ex.: https://api.seudominio.com
WEBHOOK_BASE_URL=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
# Número Twilio pra SMS de fallback (precisa ser comprado, sandbox não envia SMS pro Brasil)
TWILIO_SMS_FROM=
# ContentSid dos templates aprovados pela Meta (HX...). Opcional em sandbox.
TWILIO_TEMPLATE_ENCOMENDA_CHEGOU=
TWILIO_TEMPLATE_RETIRADA_CONFIRMADA=

# Z-API
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=

# ---- Storage de fotos (S3-compatível, MinIO em dev) ----
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=portaria-fotos
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=portaria
STORAGE_SECRET_KEY=portaria123
STORAGE_PUBLIC_URL=http://localhost:9000/portaria-fotos
